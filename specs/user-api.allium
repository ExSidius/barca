-- allium: 3
-- user-api.allium

-- Scope: Barca user-facing API contract
-- Includes: Node declarations, DAG structure, execution commands, parallel dispatch
-- Excludes:
--   - Internal execution engine (UDS, SIGSTOP, coordinator, io_loop)
--   - Persistence implementation (Turso, artifact format details)
--   - HTTP server API (separate spec)
--   - Parser implementation (ruff AST)

------------------------------------------------------------
-- Enumerations
------------------------------------------------------------

enum NodeKind { asset | sensor | task }

enum Freshness { always | manual | schedule }

enum EdgeKind { direct | collect | partition_source }

enum SerializerKind { json | parquet | pickle | text | yaml }

enum RunStatus { success | failed }

------------------------------------------------------------
-- Value Types
------------------------------------------------------------

value PartitionKey {
    dimensions: Set<String>
    -- Deterministically ordered key=value pairs (e.g., ticker=AAPL)
}

value RetryPolicy {
    retries: Integer
    retry_backoff: Decimal

    -- retries = total attempts (1 = no retry)
    -- delay before attempt N = retry_backoff * N
}

value ArtifactRef {
    path: String
    format: SerializerKind
    size_bytes: Integer
    elapsed_seconds: Decimal?
}

------------------------------------------------------------
-- External Entities
------------------------------------------------------------

external entity PythonFunction {
    -- A decorated Python function in a source file.
    -- Barca never imports it; the parser extracts metadata from the AST.
    name: String
    source_file: String
    source_text: String
}

------------------------------------------------------------
-- Entities
------------------------------------------------------------

entity Node {
    function: PythonFunction
    kind: NodeKind
    freshness: Freshness
    retry_policy: RetryPolicy
    timeout_seconds: Integer
    serializer: SerializerKind?
    description: String?
    tags: Set<String>

    -- Relationships
    inputs: Set<Edge> with downstream = this
    dependents: Set<Edge> with upstream = this

    -- Partitions
    partition_keys: Set<PartitionKey>

    -- Sinks (only for assets)
    sinks: Set<Sink> with node = this

    -- Derived
    definition_hash: String
    -- Changes when source_text, dependency cone, or metadata changes.
    -- Stable across runs when code is unchanged.
}

entity Edge {
    upstream: Node
    downstream: Node
    kind: EdgeKind
    param_name: String
    -- The function parameter on downstream that receives upstream's output
}

entity Sink {
    node: Node
    path: String
    serializer: SerializerKind?
}

entity Dag {
    nodes: Set<Node>
    edges: Set<Edge>

    -- Derived
    topo_order: Sequence<Node>
    -- Topological sort of all nodes (deterministic)
}

entity Step {
    node: Node
    partition: PartitionKey?
    -- A concrete execution unit: one node + one partition coordinate.

    -- Derived
    step_id: String
    -- Format: "source.py:function" or "source.py:function[k1=v1,k2=v2]"
}

entity Phase {
    steps: Set<Step>
    -- All steps in a phase execute concurrently.
    -- A phase barrier ensures all steps complete before the next phase starts.
}

entity ExecutionPlan {
    dag: Dag
    phases: Sequence<Phase>
    -- Phases execute in sequence. Within each phase, steps execute in parallel.
    total_steps: Integer
}

entity Materialization {
    step: Step
    run_hash: String
    artifact: ArtifactRef?
    status: RunStatus
    error_message: String?
    attempts: Integer
}

entity Run {
    command: get | run
    target: Node?
    status: RunStatus
    steps_executed: Integer
    steps_cached: Integer
    elapsed_seconds: Decimal
    final_output: String?
}

entity ParallelGroup {
    parent: Step
    children: Set<Step>
    -- Created dynamically at runtime by parallel()
}

entity BranchResult {
    step: Step
    group: ParallelGroup
    result: String?
    error: String?

    -- Derived
    succeeded: error = null
}

------------------------------------------------------------
-- Config
------------------------------------------------------------

config {
    pool_size: Integer = cpu_count
    -- Number of concurrent Python worker processes.

    default_timeout: Integer = 300
    -- Default timeout in seconds per step.

    default_retries: Integer = 1
    -- Default total attempts (1 = no retry).
}

------------------------------------------------------------
-- Rules
------------------------------------------------------------

-- ── DAG construction ─────────────────────────────────────

rule DeclareAsset {
    when: DeclareAsset(function, inputs, partitions, freshness, serializer, sinks, retry_policy, timeout)

    ensures: Node.created(
        function: function,
        kind: asset,
        freshness: freshness,
        retry_policy: retry_policy,
        timeout_seconds: timeout,
        serializer: serializer,
        partition_keys: partitions
    )
    ensures:
        for sink in sinks:
            Sink.created(node: node, path: sink.path, serializer: sink.serializer)

    @guidance
        -- Decorating with @asset() is a no-op at runtime.
        -- The Rust parser extracts all metadata from the AST.
}

rule DeclareSensor {
    when: DeclareSensor(function, freshness, retry_policy, timeout)

    ensures: Node.created(
        function: function,
        kind: sensor,
        freshness: freshness,
        retry_policy: retry_policy,
        timeout_seconds: timeout
    )
}

rule DeclareTask {
    when: DeclareTask(function, inputs, retry_policy, timeout)

    ensures: Node.created(
        function: function,
        kind: task,
        freshness: always,
        retry_policy: retry_policy,
        timeout_seconds: timeout
    )
}

rule DeclareInput {
    when: DeclareInput(downstream, param_name, upstream, collected)

    let edge_kind = if collected: collect else: direct

    ensures: Edge.created(
        upstream: upstream,
        downstream: downstream,
        kind: edge_kind,
        param_name: param_name
    )
}

-- ── DAG validation ───────────────────────────────────────

rule RejectTaskAsAssetInput {
    when: Edge.created(upstream, downstream, kind)

    requires: upstream.kind = task
    requires: downstream.kind = asset
    -- or downstream.kind = sensor

    ensures: DagValidationError(
        message: "task cannot be an input to an asset or sensor — tasks are never cached, so this would poison caching"
    )
}

rule RejectSensorWithInputs {
    when: DeclareInput(downstream, param_name, upstream, collected)
    requires: downstream.kind = sensor

    ensures: DagValidationError(
        message: "sensors cannot have inputs"
    )
}

rule RejectCycle {
    when: Dag.created(nodes, edges)
    requires: edges.any(e => path_exists(e.downstream, e.upstream))

    ensures: DagValidationError(
        message: "cycle detected in dependency graph"
    )
}

-- ── Execution: barca get ─────────────────────────────────

rule GetAsset {
    when: GetAsset(target, files, no_cache)

    requires: target = null or target.kind = asset
    -- If target specified, must be an asset. Tasks use barca run.

    let dag = build_dag(files)
    let plan = plan_execution(dag, target)

    ensures:
        for phase in plan.phases:
            for step in phase.steps:
                if not no_cache and cache_hit(step):
                    -- Skip execution, use cached artifact
                    step.status = cached
                else:
                    ExecuteStep(step)

    ensures: Run.created(
        command: get,
        target: target,
        status: success
    )

    @guidance
        -- Phases execute in sequence. Within each phase, Rust assigns
        -- steps to idle workers as they become available.
        -- Cache is keyed by run_hash: definition_hash + partition + upstream hashes.
}

-- ── Execution: barca run ─────────────────────────────────

rule RunTask {
    when: RunTask(target, files, burst)

    requires: target.kind = task
    -- Must target a task. Assets use barca get.

    let dag = build_dag(files)
    let cone = subgraph(dag, target)
    let plan = plan_execution(cone, target)

    ensures:
        for phase in plan.phases:
            for step in phase.steps:
                if step.node.kind = task:
                    -- Tasks always re-run
                    ExecuteStep(step)
                else if step.node.kind = sensor:
                    -- Sensors always re-run
                    ExecuteStep(step)
                else if step.node in burst:
                    -- Burst assets are force-rerun
                    ExecuteStep(step)
                else if cache_hit(step):
                    step.status = cached
                else:
                    ExecuteStep(step)

    ensures: Run.created(
        command: run,
        target: target,
        status: success
    )

    @guidance
        -- If burst is empty/null, ALL upstream assets are burst (force-rerun).
        -- If burst lists specific asset names, only those are force-rerun.
}

-- ── Step execution ───────────────────────────────────────

rule ExecuteStep {
    when: ExecuteStep(step)

    ensures: Materialization.created(
        step: step,
        run_hash: compute_run_hash(step),
        artifact: execute_and_serialize(step),
        status: success,
        attempts: 1
    )

    @guidance
        -- Rust assigns the step to an idle worker via UDS.
        -- Worker imports the module, calls the function, serializes the result.
        -- Ordering-only deps (_ prefix params) receive None.
        -- Sensors return (updated, data); only data is serialized.
}

rule StepFails {
    when: ExecuteStep(step)
    -- Step function raised an exception

    let policy = step.node.retry_policy

    ensures:
        if policy.retries > 1:
            -- Retry: step goes back to the ready queue
            RetryStep(step, attempt: 1)
        else:
            StepPermanentlyFailed(step)
}

rule RetryStep {
    when: RetryStep(step, attempt)
    requires: attempt < step.node.retry_policy.retries

    ensures:
        -- Wait retry_backoff * attempt seconds, then re-execute
        ExecuteStep(step)

    @guidance
        -- Each retry is a fresh worker invocation.
        -- Retries do not cascade: a parent's retry does not re-run children.
}

rule StepPermanentlyFailed {
    when: StepPermanentlyFailed(step)

    ensures: Materialization.created(
        step: step,
        status: failed
    )
    ensures:
        -- Cascade: skip all downstream data-dependent steps
        for edge in step.node.dependents:
            if edge.kind = direct or edge.kind = collect:
                StepSkipped(edge.downstream)
            -- Ordering deps are satisfied by failure (downstream still runs)
}

-- ── Parallel dispatch ────────────────────────────────────

rule ParallelRequested {
    when: ParallelRequested(parent_step, callables)
    -- A @task called parallel() with a list of functools.partial instances

    requires: parent_step.node.kind = task
    -- parallel() is only valid inside @task functions

    let group = ParallelGroup.created(
        parent: parent_step,
        children: Set<Step>
    )

    ensures:
        for callable in callables:
            let child = Step.created(node: callable.task, partition: null)
            child in group.children
            ExecuteStep(child)

    @guidance
        -- Rust freezes the parent worker (SIGSTOP), spawns a temp replacement
        -- to maintain pool capacity, and adds children to the ready queue.
        -- Children execute in parallel across available workers.
}

rule ParallelGroupCompletes {
    when: group: ParallelGroup where group.children.all(c => c.status in {success, failed})

    ensures:
        for child in group.children:
            if child.status = success:
                BranchResult.created(step: child, group: group, result: child.output)
            else:
                BranchResult.created(step: child, group: group, error: child.error_message)

    ensures:
        -- Resume the parent: kill temp replacement, SIGCONT original,
        -- send results list in argument order.
        -- Parent receives list of values or ParallelError objects.
        ResumeParent(group.parent, results: group.results_in_order)

    @guidance
        -- Promise.allSettled semantics: no branch failure crashes the parent.
        -- The parent continues executing after parallel() returns.
        -- Results are ordered by argument position, not completion order.
}

-- ── Cache ────────────────────────────────────────────────

rule CacheHit {
    when: cache_hit(step)
    -- A previous materialization exists with matching run_hash

    requires: step.node.kind = asset
    -- Only assets are cached. Tasks and sensors always re-run.

    let previous = most_recent_materialization(step, run_hash)
    requires: previous.status = success

    ensures: step.output = previous.artifact
    -- Reuse the previous artifact without re-executing
}

------------------------------------------------------------
-- Invariants
------------------------------------------------------------

invariant TasksNeverCached {
    -- Tasks are never served from cache, regardless of hash match.
    for node in Dag.nodes:
        if node.kind = task:
            node.materializations.none(m => m.status = cached)
}

invariant SensorsNeverCached {
    -- Sensors always re-run on every execution.
    for node in Dag.nodes:
        if node.kind = sensor:
            node.materializations.none(m => m.status = cached)
}

invariant SensorsHaveNoInputs {
    -- Sensors observe external state; they cannot depend on other nodes.
    for node in Dag.nodes:
        if node.kind = sensor:
            node.inputs.count = 0
}

invariant TasksCannotFeedAssets {
    -- A task's output cannot be an input to an asset or sensor.
    for edge in Dag.edges:
        if edge.upstream.kind = task:
            edge.downstream.kind = task
}

invariant NoCycles {
    -- The dependency graph is a DAG (directed acyclic graph).
    Dag.topo_order exists
}

invariant StepAccountingInvariant {
    -- Every step loaded into the execution engine reaches a terminal state.
    -- No step can be silently dropped.
    for step in ExecutionPlan.steps:
        step.status in {success, failed, skipped, cached}
}

invariant ParallelResultsOrdered {
    -- parallel() returns results in argument order, not completion order.
    for group in ParallelGroups:
        group.results_in_order.count = group.children.count
}

invariant OrderingDepsCarryNoData {
    -- Parameters prefixed with _ receive None, not upstream output.
    for edge in Dag.edges:
        if edge.param_name.starts_with("_"):
            edge.downstream receives null for edge.param_name
}

invariant SensorUnpacking {
    -- Sensors return (updated, data). Only data is passed downstream.
    -- The updated flag is consumed by the orchestrator, not by user code.
    for node in Dag.nodes:
        if node.kind = sensor:
            node.downstream_consumers receive node.output.data, not node.output
}

------------------------------------------------------------
-- Surfaces
------------------------------------------------------------

surface PythonDecorators {
    -- The user-facing Python API: decorators that declare the DAG.
    facing user: PythonDeveloper

    provides:
        DeclareAsset(function, inputs, partitions, freshness, serializer, sinks, retry_policy, timeout)
        DeclareSensor(function, freshness, retry_policy, timeout)
        DeclareTask(function, inputs, retry_policy, timeout)
        DeclareInput(downstream, param_name, upstream, collected)

    @guarantee DecoratorsAreNoOps
        -- All decorators are identity functions. User code runs
        -- identically with or without barca installed.

    @guarantee StaticAnalysisOnly
        -- Barca never imports user modules during planning.
        -- The DAG is built entirely from AST analysis.
}

surface Cli {
    -- The barca CLI: commands that execute the DAG.
    facing user: PythonDeveloper

    provides:
        GetAsset(target, files, no_cache)
        RunTask(target, files, burst)
        PlanDag(files)
        ShowHistory(limit)
        ShowStats(target, files)

    @guarantee GetIsForAssets
        -- barca get targets assets. Using it on a task gives a clear error.

    @guarantee RunIsForTasks
        -- barca run targets tasks. Using it on an asset gives a clear error.

    @guarantee PlanIsReadOnly
        -- barca plan never executes anything. Deterministic output.
}

surface ParallelApi {
    -- The parallel() primitive for dynamic fan-out within tasks.
    facing user: PythonDeveloper

    provides:
        ParallelRequested(parent_step, callables)

    @guarantee ArgumentOrderPreserved
        -- Results are returned in the same order as the input arguments,
        -- regardless of which branches complete first.

    @guarantee BranchIsolation
        -- A failed branch does not crash the parent or other branches.
        -- Failed branches produce ParallelError objects in the results list.

    @guarantee OnlyInTasks
        -- parallel() is only valid inside @task functions.
        -- Using it in an @asset body is an anti-pattern.
}

------------------------------------------------------------
-- Open Questions
------------------------------------------------------------

-- 1. Schedule enforcement: Schedule("0 5 * * *") is declared but not
--    yet enforced at runtime. Scheduled assets behave like Always until
--    cron enforcement ships in v0.3.0.

-- 2. Remote sink storage: @sink paths are local-only in v0.2.0.
--    S3/R2/GCS support planned for v0.3.0.

-- 3. Backoff on retries: coordinator retries immediately (push back to
--    ready queue). Exponential backoff is declared but not enforced.

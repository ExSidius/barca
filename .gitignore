# Python
__pycache__/
*.py[codz]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/

# Rust
/target/
**/*.rs.bk
*.pdb

# Environments (`.venv` without the slash also catches venv symlinks,
# e.g. benchmark dirs pointing at a shared framework venv)
.env
.envrc
.venv
.venv/

# Barca runtime state
.barca/
.barcafiles/
tmp/

# Example lock files (regenerated by uv sync)
examples/*/uv.lock

# Vendored dependencies
vendor/

# Editors / OS / AI
.vscode/
.idea/
.cursor/
.claude/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Linters / caches
.ruff_cache/
.mypy_cache/
.pytest_cache/

# Benchmark auto-generated hyperfine output (per-benchmark dir)
benchmarks/*/results.md

# MkDocs
site/
